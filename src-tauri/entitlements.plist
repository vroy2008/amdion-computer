<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Entitlements applied under the hardened runtime, which Apple requires for
    notarized Developer ID distribution. These are the minimum an Amdion build
    needs:
      - JIT / unsigned executable memory: the WKWebView (JavaScriptCore) needs
        it, or the panel renders blank under hardened runtime.
      - network client: reqwest calls (Gemini, the updater fetch).
      - network server: the loopback WebSocket bridge the Chrome extension
        connects to (bridge_ws.rs, ports 17872-17882).
    No App Sandbox key — this is direct Developer ID distribution, not the Mac
    App Store, so the NSWorkspace / CoreGraphics / global-shortcut access the
    app relies on keeps working.
  -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
