{
  "manifest_version": 3,
  "name": "Amdion Companion",
  "version": "1.0.0",
  "description": "Connects your Chrome to Amdion — reports activity and applies the attention friction you choose. All data stays on your device.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": [
    "tabs",
    "webNavigation",
    "idle",
    "storage",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "core/background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Amdion — attention companion",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-read-mode": {
      "suggested_key": { "default": "Ctrl+Shift+R", "mac": "MacCtrl+Shift+R" },
      "description": "Read this page calmly (Amdion Read Mode)"
    },
    "capture-tab": {
      "suggested_key": { "default": "Ctrl+Shift+C", "mac": "MacCtrl+Shift+C" },
      "description": "Capture this tab to Amdion Notes (screenshot)"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["features/reshape/reshape.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["core/nudge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["features/notes/capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "features/read-mode/vendor/readability.js",
        "features/read-mode/vendor/readability-readerable.js",
        "features/read-mode/reader.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.linkedin.com/*"
      ],
      "js": ["features/reshape/feedfade.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["features/reshape/ytdrift.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.linkedin.com/*",
        "*://*.instagram.com/*"
      ],
      "css": ["features/reshape/declutter.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["blocked.html"], "matches": ["<all_urls>"] }
  ]
}
