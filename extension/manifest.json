{
  "manifest_version": 3,
  "name": "Amdion Companion",
  "version": "1.0.0",
  "description": "Connects your Chrome to Amdion — reports activity and applies the attention friction you choose. All data stays on your device.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": [
    "tabs",
    "webNavigation",
    "idle",
    "storage",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Amdion — attention companion" },
  "commands": {
    "toggle-read-mode": {
      "suggested_key": { "default": "Alt+Shift+R", "mac": "Alt+Shift+R" },
      "description": "Read this page calmly (Amdion Read Mode)"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/nudge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/vendor/readability.js",
        "content/vendor/readability-readerable.js",
        "content/reader.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*", "*://*.x.com/*", "*://*.twitter.com/*"],
      "css": ["content/declutter.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["blocked.html"], "matches": ["<all_urls>"] }
  ]
}
