{
  "name": "amdion-desktop",
  "version": "1.0.0",
  "description": "AMDION Focused Computer - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "package": "npx @electron/packager . AMDION --platform=win32 --arch=x64 --icon=icon.ico --out=dist --overwrite --ignore=\"observer-mvp|docs|amdion_logo_new\\.png|build-dmg\\.sh|journals|\\.gitignore\""
  },
  "author": "AMDION",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.amdion.desktop",
    "productName": "AMDION",
    "files": [
      "**/*",
      "!observer-mvp/**",
      "!docs/**",
      "!amdion_logo_new.png",
      "!build-dmg.sh",
      "!journals/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "dotenv": "^17.3.1"
  }
}
